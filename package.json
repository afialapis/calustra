{
  "name": "calustra",
  "version": "1.0.0-beta.14",
  "description": "Database connections",
  "author": "Donato Lorenzo <donato@afialapis.com>",
  "contributors": [
    "Donato Lorenzo <donato@afialapis.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/afialapis/calustra.git"
  },
  "bugs": {
    "url": "https://github.com/afialapis/calustra/issues"
  },
  "homepage": "https://www.afialapis.com/os/calustra",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./src/conn/postgres/index.mjs",
    "./conn-postgres": "./src/conn/postgres/index.mjs",
    "./conn-sqlite": "./src/conn/sqlite/index.mjs",
    "./query": "./src/query/index.mjs"
  },
  "files": [
    "src",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "imports": {
    "#conn-base/*": "./src/conn/base/*",
    "#conn-postgres/*": "./src/conn/postgres/*",
    "#conn-sqlite/*": "./src/conn/sqlite/*",
    "#query/*": "./src/query/*"
  },
  "scripts": {
    "reset": "rm -fr arredemo node_modules package-lock.json && npm i",
    "lint": "biome check ./src ./test --reporter=github",
    "lint:fix": "biome check --write ./src ./test --reporter=github",
    "test": "node --test ./test/index.mjs",
    "site": "npx arredemo build",
    "prepublishOnly": "npm run lint && npm run test && npm run site"
  },
  "dependencies": {
    "cacheiro": "^0.5.0-beta.11",
    "farrapa": "^3.0.0-beta.10",
    "intre": "^3.0.0-beta.4",
    "pg-promise": "^12.6.2",
    "sqlite3": "^5.1.7",
    "tinguir": "^0.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  },
  "overrides": {
    "tar": "^7.5.8"
  },
  "engines": {
    "node": ">=24"
  }
}